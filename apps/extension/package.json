{
  "name": "@retrace/extension",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "lint": "tsc --noEmit",
    "postinstall": "wxt prepare",
    "typecheck": "tsc --noEmit",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox"
  },
  "dependencies": {
    "@retrace/config": "workspace:*",
    "@retrace/types": "workspace:*",
    "@wxt-dev/module-react": "^1.2.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "wxt": "^0.20.26"
  },
  "devDependencies": {
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "typescript": "^5.9.3"
  }
}
